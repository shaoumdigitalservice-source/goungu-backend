# Copier ce fichier en ".env" (jamais commité) et remplir les vraies valeurs.
# Générer un secret fort : openssl rand -base64 32

DB_NAME=goungue_db
DB_PASSWORD=change-moi-mot-de-passe-mysql-fort

JWT_SECRET=
SETUP_SECRET_KEY=

# Laisser à true tant que le premier admin n'a pas été créé sur cet environnement.
# Passer à false juste après (POST /api/setup/create-admin renverra alors 404).
SETUP_ENABLED=true

# En prod sur le VPS, mettre le(s) domaine(s) réel(s), séparés par une virgule si plusieurs :
# CORS_ALLOWED_ORIGINS=https://votre-domaine.com
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# Utilisé uniquement par docker-compose.prod.yml (Caddy) — le nom de domaine qui pointe vers le VPS.
# Inutile en local.
DOMAIN=votre-domaine.com

# Utilisé uniquement par docker-compose.shared-caddy.yml (VPS mutualisé, Caddy
# central déjà en place) — nom du réseau Docker externe de ce Caddy. Le mettre
# ici évite d'avoir à le repréciser sur la ligne de commande à chaque redéploiement.
EXTERNAL_CADDY_NETWORK=edge
